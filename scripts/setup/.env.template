# === 生产线环境配置 ===

# Worker 标识（每台机器唯一）
WORKER_ID=worker-1

# 共享存储挂载点
SHARED_DIR=/Volumes/shared

# 主控 IP（SMB 连接用）
CONTROLLER_IP=192.168.1.100

# 云雾 API Key（图片生成）
YUNWU_API_KEY=your_key_here

# Kimi CLI 配置
KIMI_API_KEY=your_key_here

# Chrome CDP 端口（即梦自动化）
CDP_PORT=18781

# 即梦 Chrome 用户数据目录
JIMENG_CHROME_PROFILE=/tmp/jimeng-profile

# AI Agent 调用方式 (claude / codex / openai-api)
AI_AGENT=claude

# 项目根目录
PROJECT_ROOT=/Users/shared/production

# 轮询间隔（秒）
POLL_INTERVAL=30

# 日志级别 (debug / info / warn / error)
LOG_LEVEL=info

# === 审核系统 ===
# Review Server URL（留空则不上报）
REVIEW_SERVER_URL=http://107.175.215.216:3000
# Dispatcher Token（从 review-server .env 获取）
DISPATCHER_TOKEN=your_dispatcher_token_here

# === YouTube 下载 ===
# yt-dlp cookies 来源浏览器（chrome/firefox/edge）
YT_COOKIES_BROWSER=chrome
