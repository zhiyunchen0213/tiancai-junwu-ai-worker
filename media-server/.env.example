# media-server environment (零依赖 Node HTTP server)
# 此文件仅作文档参考 — 实际生产 env 写在 LaunchAgent plist 的 EnvironmentVariables
# dict 里，不从 .env 文件加载（launchd 不读 shell env）。
#
# 本地跑 (非生产) 时，可以用 dotenv 或 inline env 传入：
#   MEDIA_TOKEN=xxx MEDIA_ROOT=./test-deliveries node server.mjs

# 监听端口 (Cloudflare Tunnel 映射 media.createflow.art → localhost:PORT)
PORT=9000

# 共享密钥, VPS 端 review-server/.env 的 MEDIA_TOKEN 必须一致.
# 生成: openssl rand -hex 32
MEDIA_TOKEN=

# 服务的根目录, 所有静态文件请求都会限制在此目录内 (path traversal 防御).
MEDIA_ROOT=/Users/zjw-mini/production/deliveries
